    <!-- Category Distance -->
    <string name="cat_distance_title">Distance Ranking</string>
    <string name="title_dist_today">Today\'s Effort</string>
    <string name="desc_dist_today">Compete by accumulating the most kilometers within a single day. This ranking resets precisely at 00:00 (Midnight) every day. Every step counts toward climbing the daily chart!</string>
    <string name="title_dist_week">Weekly Challenge</string>
    <string name="desc_dist_week">Your total distance is summed up starting from Monday at 00:00 until Sunday night. It is the perfect way to track your progress against others throughout the week. Resets every Monday morning.</string>
    <string name="title_dist_month">Monthly Marathon</string>
    <string name="desc_dist_month">A long-term test of endurance. This leaderboard tracks all kilometers run from the 1st day of the month to the last. Resets at the start of each new calendar month.</string>

    <!-- Category Best Pace -->
    <string name="cat_pace_title">Speed &amp; Performance</string>
    <string name="title_pace_today">Today\'s Fastest</string>
    <string name="desc_pace_today">Ranked by your highest average pace recorded in a single run session today. **To qualify, the run must be at least 3.0 km long** to ensure a fair and accurate measurement of your speed.</string>
    <string name="title_pace_week">Weekly Speedster</string>
    <string name="desc_pace_week">Who was the fastest runner this week? This list shows the best pace records achieved since Monday. Only activities covering **3.0 km or more** are eligible for this prestigious list.</string>
    <string name="title_pace_month">Monthly Elite</string>
    <string name="desc_pace_month">The definitive list of the fastest runners this month. Your best single-session pace record is compared against the community. Requires a minimum distance of **3.0 km** per activity.</string>

    <!-- Category Streak -->
    <string name="cat_streak_title">Consistency (Streak)</string>
    <string name="title_streak_today">Active Streak</string>
    <string name="desc_streak_today">Ranked by your current number of consecutive active days. To maintain your streak, you must record at least one activity every single day. If you miss a day, your streak returns to zero!</string>
    <string name="title_streak_week">Weekly Dedication</string>
    <string name="desc_streak_week">Shows the highest streak count maintained by users during the current week. It rewards those who show up every day without fail from Monday to Sunday.</string>
    <string name="title_streak_month">Monthly Commitment</string>
    <string name="desc_streak_month">The ultimate test of habit. This ranking highlights runners who have remained consistent throughout the entire month. The longer your streak, the higher you climb!</string>

