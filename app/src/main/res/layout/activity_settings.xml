<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/rounded_card"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Pengaturan Profil"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Weight -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Berat Badan (kg)"
                android:textColor="@color/muted_fg"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etWeight"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/card_glass"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp" />

            <!-- Monthly Target -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Target Bulanan (km)"
                android:textColor="@color/muted_fg"
                android:layout_marginBottom="8dp" />
            <EditText
                android:id="@+id/etMonthlyTarget"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/card_glass"
                android:paddingHorizontal="16dp"
                android:inputType="number"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="32dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Simpan Perubahan"
                android:textColor="@color/bg"
                android:textStyle="bold"
                android:background="@drawable/btn_lime" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
