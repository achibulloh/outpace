<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_glass"
    android:padding="20dp"
    android:layout_marginBottom="14dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">
        <FrameLayout
            android:id="@+id/iconRunContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/icon_circle_bg"
            android:layout_marginEnd="14dp">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_run_path"
                app:tint="@color/lime"/>
        </FrameLayout>
        <LinearLayout
            android:orientation="vertical"
            android:layout_toEndOf="@id/iconRunContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvRunTitle"
                android:text="Run"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="17sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvRunDate"
                android:text="Date"
                android:textColor="@color/muted_fg"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
        <ImageView
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_play"
            android:alpha="0.4"
            app:tint="@color/text_primary"/>
    </RelativeLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
            <TextView android:id="@+id/tvHistoryDistance" android:text="0.0 km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Jarak" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
            <TextView android:id="@+id/tvHistoryDuration" android:text="00:00" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Durasi" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
            <TextView android:id="@+id/tvHistoryPace" android:text="0:00/km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="Pace" android:textColor="@color/muted_fg" android:textSize="11sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
