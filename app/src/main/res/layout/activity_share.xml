<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- 1) Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <FrameLayout
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/icon_circle_bg"
            android:backgroundTint="@color/lime">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                app:tint="@color/bg" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Bagikan Aktivitas"
            android:textColor="@color/text_primary"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 2) Mode selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:id="@+id/tabDefault"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_tab_selected"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvTabPolosLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OUTPACE"
                android:textColor="@color/lime"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTabPolosValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.2"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTabPolosSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5:14 /km · 27:14"
                android:textColor="@color/muted_fg"
                android:textSize="9sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvTabPolosMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Polos"
                android:textColor="@color/lime"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabPaceTheme"
            android:layout_width="0dp"
            android:layout_height="96dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/card_glass"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_run_path"
                app:tint="@color/muted_fg"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvTabThemeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OUTPACE Theme"
                android:textColor="@color/muted_fg"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- 3) Preview Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/previewContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:background="@color/bg">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginVertical="12dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="#000000"
            app:strokeWidth="0dp"
            app:cardPreventCornerOverlap="false"
            app:layout_constraintDimensionRatio="9:16"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_checkerboard"/>

            <FrameLayout
                android:id="@+id/shareFrame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:clipChildren="false"
                android:clipToPadding="false">
            </FrameLayout>

        </com.google.android.material.card.MaterialCardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 4) Theme navigator -->
    <LinearLayout
        android:id="@+id/paceStyleSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingVertical="12dp"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/btnThemePrev"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/nav_arrow_bg"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                app:tint="@color/lime" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/dotsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginHorizontal="16dp">
        </LinearLayout>

        <FrameLayout
            android:id="@+id/btnThemeNext"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/nav_arrow_bg"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_back"
                android:rotation="180"
                app:tint="@color/lime" />
        </FrameLayout>
    </LinearLayout>

    <!-- 5) Panel Kontrol -->
    <LinearLayout
        android:id="@+id/panelContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_glass"
        android:elevation="12dp"
        android:paddingTop="16dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp">

                <!-- Top Level Trigger Button -->
                <LinearLayout
                    android:id="@+id/btnOpenBgEditor"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/btn_glass_pill"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_edit"
                        android:layout_marginEnd="10dp"
                        app:tint="@color/lime"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganti Latar"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Background Editor Panel (Hidden by default) -->
                <LinearLayout
                    android:id="@+id/layoutBgEditor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/card_glass"
                    android:backgroundTint="#0DFFFFFF"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilih Warna Latar"
                        android:textColor="@color/lime"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="16dp">
                        <LinearLayout
                            android:id="@+id/llBgColorContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="4dp"/>
                    </HorizontalScrollView>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#20FFFFFF"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:id="@+id/btnAddImage"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/btn_glass_pill"
                        android:backgroundTint="#1AFFFFFF"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_edit"
                            android:layout_marginEnd="8dp"
                            app:tint="@color/text_primary"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pilih Gambar dari Galeri"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/defaultControls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/elementEditor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_glass"
                        android:backgroundTint="#0DFFFFFF"
                        android:padding="16dp"
                        android:layout_marginBottom="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/selectedElementName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nama Elemen"
                            android:textColor="@color/lime"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:layout_marginBottom="16dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="Size"
                                android:textColor="@color/muted_fg"
                                android:textSize="12sp"/>
                            <SeekBar android:id="@+id/sbSize"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="50"
                                android:progressDrawable="@drawable/seekbar_track"
                                android:thumb="@drawable/seekbar_thumb"
                                android:splitTrack="false"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="Rotate"
                                android:textColor="@color/muted_fg"
                                android:textSize="12sp"/>
                            <SeekBar android:id="@+id/sbRotation"
                                android:layout_width="0dp"
                                android:layout_height="32dp"
                                android:layout_weight="1"
                                android:max="360"
                                android:progress="180"
                                android:progressDrawable="@drawable/seekbar_track"
                                android:thumb="@drawable/seekbar_thumb"
                                android:splitTrack="false"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <TextView
            android:id="@+id/btnSaveShare"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/btn_lime"
            android:gravity="center"
            android:text="Simpan &amp; Bagikan"
            android:textColor="@color/bg"
            android:textStyle="bold"
            android:textSize="15sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

</LinearLayout>
