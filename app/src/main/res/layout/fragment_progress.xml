<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:scrollbars="none"
    android:forceDarkAllowed="false"
    tools:targetApi="q">

    <LinearLayout
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="110dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- HEADER -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <TextView
                android:text="Progress"
                android:textColor="@color/text_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <FrameLayout
                android:id="@+id/btnLeaderboard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/btn_leaderboard"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_trophy"
                        android:layout_marginEnd="6dp"/>
                    <TextView
                        android:text="Leaderboard"
                        android:textColor="@color/lime"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- CARD TARGET BULANAN -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">
                <TextView
                    android:text="Target Bulanan"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvMonthlyTargetKm"
                    android:text="150 km"
                    android:textColor="@color/lime"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/progress_track"
                android:layout_marginBottom="10dp">
                <View
                    android:id="@+id/progressMonthly"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/progress_fill"/>
            </FrameLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tvTargetAchieved"
                    android:text="0.0 km tercapai"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvTargetPercent"
                    android:text="0%"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CARD TARGET MINGGUAN -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">
                <TextView
                    android:text="Target Mingguan"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvWeeklyTargetKm"
                    android:text="37.5 km"
                    android:textColor="@color/lime"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@drawable/progress_track"
                android:layout_marginBottom="10dp">
                <View
                    android:id="@+id/progressWeekly"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/progress_fill"/>
            </FrameLayout>

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:id="@+id/tvWeeklyAchieved"
                    android:text="0.0 km tercapai"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvWeeklyPercent"
                    android:text="0%"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- CARD JARAK MINGGUAN (Bar Chart) -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">
                <TextView
                    android:text="Jarak Mingguan"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvWeeklyRange"
                    android:text="6 - 12 Jun 2026"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <com.example.pace.views.BarChartView
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="160dp"/>
        </LinearLayout>

        <!-- CARD TREN PACE (Line Chart) -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:text="Tren Pace"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_marginEnd="4dp"
                        app:tint="@color/lime"/>
                    <TextView
                        android:id="@+id/tvPaceTrend"
                        android:text="Membaik"
                        android:textColor="@color/lime"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <com.example.pace.views.LineChartView
                android:id="@+id/lineChart"
                android:layout_width="match_parent"
                android:layout_height="140dp"/>
        </LinearLayout>

        <!-- CARD KONSISTENSI HARIAN -->
        <LinearLayout
            android:orientation="vertical"
            android:padding="20dp"
            android:background="@drawable/card_glass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">
                <TextView
                    android:text="Konsistensi Harian"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:id="@+id/tvCurrentMonthYear"
                    android:text="Juni 2026"
                    android:textColor="@color/muted_fg"
                    android:textSize="13sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <com.example.pace.views.CalendarDotsView
                android:id="@+id/calendarDots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
