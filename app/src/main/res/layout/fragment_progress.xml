<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:orientation="vertical"
    android:forceDarkAllowed="false"
    tools:targetApi="q">

    <!-- FIXED HEADER -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="20dp">

        <TextView
            android:text="@string/progress_title"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnLeaderboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/muted"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/muted"
            app:strokeWidth="1dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_trophy"
                    android:layout_marginEnd="8dp"
                    app:tint="@color/lime"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/leaderboard"
                    android:textColor="@color/lime"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="110dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- AI Progress Insight -->
            <LinearLayout
                android:id="@+id/layoutAIProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:background="@drawable/card_glass"
                android:padding="20dp"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_logo"
                        app:tint="@color/lime"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_coach_title"
                        android:textColor="@color/lime"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
                <TextView
                    android:id="@+id/tvAIProgressInsights"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/ai_generating"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp"
                    android:alpha="0.8"/>
            </LinearLayout>

            <!-- CARD TARGET BULANAN -->
            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/card_glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:text="@string/monthly_target_title"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvMonthlyTargetKm"
                        tools:text="0.0 km"
                        android:textColor="@color/lime"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="@drawable/progress_track"
                    android:layout_marginBottom="10dp">
                    <View
                        android:id="@+id/progressMonthly"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/progress_fill"/>
                </FrameLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvTargetAchieved"
                        tools:text="0.0 km tercapai"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvTargetPercent"
                        tools:text="0%"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CARD TARGET MINGGUAN -->
            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/card_glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp">
                    <TextView
                        android:text="@string/weekly_target_title"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvWeeklyTargetKm"
                        tools:text="0.0 km"
                        android:textColor="@color/lime"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:background="@drawable/progress_track"
                    android:layout_marginBottom="10dp">
                    <View
                        android:id="@+id/progressWeekly"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/progress_fill"/>
                </FrameLayout>

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:id="@+id/tvWeeklyAchieved"
                        tools:text="0.0 km tercapai"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvWeeklyPercent"
                        tools:text="0%"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CARD JARAK MINGGUAN (Bar Chart) -->
            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/card_glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">
                    <TextView
                        android:text="@string/weekly_distance"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvWeeklyRange"
                        tools:text="6 - 12 Jun 2026"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <com.example.pace.views.BarChartView
                    android:id="@+id/barChart"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"/>
            </LinearLayout>

            <!-- CARD TREN PACE (Line Chart) -->
            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/card_glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:text="@string/pace_trend"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_down"
                            android:layout_marginEnd="4dp"
                            app:tint="@color/lime"/>
                        <TextView
                            android:id="@+id/tvPaceTrend"
                            android:text="@string/pace_improving"
                            android:textColor="@color/lime"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <com.example.pace.views.LineChartView
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"/>
            </LinearLayout>

            <!-- CARD KONSISTENSI HARIAN -->
            <LinearLayout
                android:orientation="vertical"
                android:padding="20dp"
                android:background="@drawable/card_glass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:text="@string/daily_consistency"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/tvCurrentMonthYear"
                        tools:text="Juni 2026"
                        android:textColor="@color/muted_fg"
                        android:textSize="13sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <com.example.pace.views.CalendarDotsView
                    android:id="@+id/calendarDots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
