<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="1080px"
    android:layout_height="1920px"
    android:background="@color/bg"
    android:padding="80px">

    <ImageView
        android:id="@+id/ivShareBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bottom_nav_gradient" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="200px"
            android:layout_height="200px"
            app:cardCornerRadius="100px"
            app:cardBackgroundColor="#22C8F43A"
            app:strokeColor="@color/lime"
            app:strokeWidth="4px">
            <ImageView
                android:layout_width="100px"
                android:layout_height="100px"
                android:layout_gravity="center"
                android:src="@drawable/ic_trophy"
                app:tint="@color/lime"/>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvShareTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MORNING RUN"
            android:textColor="@color/lime"
            android:textSize="42px"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="60px"/>

        <TextView
            android:id="@+id/tvLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bandung, Indonesia"
            android:textColor="@color/text_primary"
            android:textSize="28px"
            android:alpha="0.6"
            android:layout_marginTop="10px"/>

        <TextView
            android:id="@+id/tvShareJarak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5.20"
            android:textColor="@color/text_primary"
            android:textSize="260px"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:layout_marginTop="20px"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="kilometer"
            android:textColor="@color/muted_fg"
            android:textSize="56px"
            android:layout_marginTop="-40px"/>

        <View
            android:layout_width="1dp"
            android:layout_height="100px"
            android:background="@color/muted"
            android:layout_marginTop="60px"
            android:layout_marginBottom="60px"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="27:14" android:id="@+id/tvShareWaktu" android:textColor="@color/text_primary" android:textSize="72px" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WAKTU" android:textColor="@color/muted_fg" android:textSize="32px" android:textStyle="bold" android:layout_marginTop="8px"/>
            </LinearLayout>
            <View android:layout_width="2px" android:layout_height="80px" android:background="#22FFFFFF" android:layout_gravity="center_vertical"/>
            <LinearLayout android:orientation="vertical" android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content" android:gravity="center">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5:14/km" android:id="@+id/tvSharePace" android:textColor="@color/text_primary" android:textSize="72px" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PACE" android:textColor="@color/muted_fg" android:textSize="32px" android:textStyle="bold" android:layout_marginTop="8px"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="40px">
        <ImageView
            android:layout_width="50px"
            android:layout_height="50px"
            android:src="@drawable/ic_logo"
            app:tint="@color/lime"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OUTPACE"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="36px"
            android:layout_marginStart="16px"
            android:letterSpacing="0.2"/>
    </LinearLayout>

</RelativeLayout>
