<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="1080px"
    android:layout_height="1920px"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@color/bg">

    <!-- Background Map Image -->
    <ImageView
        android:id="@+id/ivShareBg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#000000"/>

    <!-- Map Route Overlay (Visible and positioned above the card) -->
    <com.example.pace.views.PathDrawingView
        android:id="@+id/ivSharePath"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingLeft="320px"
        android:paddingRight="320px"
        android:paddingTop="250px"
        android:paddingBottom="1250px"
        android:visibility="visible" />

    <!-- Hidden PathDrawingView for build compatibility -->
    <com.example.pace.views.PathDrawingView
        android:id="@+id/ivSharePathBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- OUTPACE Title Header -->
    <TextView
        android:id="@+id/tvPaceLogoLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OUTPACE"
        android:textColor="@color/lime"
        android:textSize="160px"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100px"
        android:letterSpacing="0.05"
        android:elevation="10dp"
        android:shadowColor="#80000000"
        android:shadowDx="0"
        android:shadowDy="4"
        android:shadowRadius="10"/>

    <!-- Bottom Stats Card matching the photo -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:layout_margin="50px"
        android:padding="60px"
        android:background="@drawable/card_glass"
        android:elevation="15dp">

        <TextView
            android:id="@+id/tvShareTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EVENING RUN"
            android:textColor="@color/lime"
            android:textSize="32px"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8px"
            android:gravity="center_vertical">
<!--            <TextView-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:text="📍"-->
<!--                android:textSize="28px"-->
<!--                android:layout_marginEnd="8px"/>-->
            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kota Bandung, Kebonwaru"
                android:textColor="@color/text_primary"
                android:textSize="28px"
                android:alpha="0.8"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JARAK TOTAL"
            android:textColor="@color/muted_fg"
            android:textSize="28px"
            android:layout_marginTop="40px"
            android:letterSpacing="0.1"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvShareJarak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="@color/white"
            android:textSize="180px"
            android:textStyle="bold"
            android:layout_marginTop="-20px"
            android:includeFontPadding="false"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="40px"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DURASI"
                    android:textColor="@color/muted_fg"
                    android:textSize="22px"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvShareWaktu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="06:47"
                    android:textColor="@color/white"
                    android:textSize="64px"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="RITME"
                    android:textColor="@color/muted_fg"
                    android:textSize="22px"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tvSharePace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3:12"
                    android:textColor="@color/white"
                    android:textSize="64px"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
