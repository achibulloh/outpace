<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="80dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <TextView
            android:text="Hei, Adi 👋"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Stats row -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <LinearLayout android:id="@+id/cardStreak"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/rounded_card">
                <TextView android:text="🔥" android:textSize="20sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="12" android:textColor="@color/text_primary"
                    android:textSize="18sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Streak" android:textColor="@color/muted_fg"
                    android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cardKm"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/rounded_card">
                <TextView android:text="⚡" android:textSize="20sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="36.2" android:textColor="@color/lime"
                    android:textSize="18sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="km minggu ini" android:textColor="@color/muted_fg"
                    android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/cardCalories"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="12dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:background="@drawable/rounded_card">
                <TextView android:text="🫀" android:textSize="20sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="847" android:textColor="@color/text_primary"
                    android:textSize="18sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="kkal" android:textColor="@color/muted_fg"
                    android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Tombol Mulai Lari -->
        <Button
            android:id="@+id/btnStartRun"
            android:text="▶  Mulai Lari"
            android:textColor="@color/bg"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_lime"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"/>

        <!-- Recent Activity title -->
        <TextView
            android:text="Aktivitas Terakhir"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Activity item 1 -->
        <LinearLayout
            android:orientation="horizontal"
            android:padding="16dp"
            android:layout_marginBottom="10dp"
            android:gravity="center_vertical"
            android:background="@drawable/rounded_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:layout_weight="1"
                android:layout_width="0dp" android:layout_height="wrap_content">
                <TextView android:text="Morning Run" android:textColor="@color/text_primary"
                    android:textStyle="bold" android:textSize="14sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Hari ini · 06:30" android:textColor="@color/muted_fg"
                    android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:orientation="vertical" android:gravity="end"
                android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView android:text="5.2 km" android:textColor="@color/text_primary"
                    android:textStyle="bold" android:textSize="14sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="5:14/km" android:textColor="@color/muted_fg"
                    android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Activity item 2 -->
        <LinearLayout
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="@drawable/rounded_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout android:orientation="vertical" android:layout_weight="1"
                android:layout_width="0dp" android:layout_height="wrap_content">
                <TextView android:text="Long Run" android:textColor="@color/text_primary"
                    android:textStyle="bold" android:textSize="14sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Kemarin · 07:00" android:textColor="@color/muted_fg"
                    android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
            <LinearLayout android:orientation="vertical" android:gravity="end"
                android:layout_width="wrap_content" android:layout_height="wrap_content">
                <TextView android:text="7.8 km" android:textColor="@color/text_primary"
                    android:textStyle="bold" android:textSize="14sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="5:27/km" android:textColor="@color/muted_fg"
                    android:textSize="12sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>