<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- Simulasi Peta (area gelap) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D1117">

        <TextView
            android:text="📍 GPS Aktif"
            android:textColor="@color/lime"
            android:textSize="13sp"
            android:padding="12dp"
            android:layout_gravity="top|start"/>

        <!-- Dot posisi user -->
        <View
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:background="@color/lime"/>
    </FrameLayout>

    <!-- Panel Stats -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Durasi, Jarak, Pace -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <LinearLayout android:orientation="vertical" android:gravity="center"
                android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvDuration" android:text="00:00"
                    android:textColor="@color/text_primary" android:textSize="28sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="DURASI" android:textColor="@color/muted_fg" android:textSize="10sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:orientation="vertical" android:gravity="center"
                android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvDistance" android:text="0.00"
                    android:textColor="@color/lime" android:textSize="28sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="KM" android:textColor="@color/muted_fg" android:textSize="10sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:orientation="vertical" android:gravity="center"
                android:layout_weight="1" android:layout_width="0dp" android:layout_height="wrap_content">
                <TextView android:id="@+id/tvPace" android:text="--:--"
                    android:textColor="@color/text_primary" android:textSize="28sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="PACE /KM" android:textColor="@color/muted_fg" android:textSize="10sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Kalori & Langkah -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <LinearLayout android:orientation="vertical" android:gravity="center"
                android:layout_weight="1" android:padding="10dp"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_marginEnd="8dp" android:background="@drawable/rounded_card">
                <TextView android:id="@+id/tvCalories" android:text="0"
                    android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Kalori" android:textColor="@color/muted_fg" android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout android:orientation="vertical" android:gravity="center"
                android:layout_weight="1" android:padding="10dp"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:background="@drawable/rounded_card">
                <TextView android:id="@+id/tvSteps" android:text="0"
                    android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                <TextView android:text="Langkah" android:textColor="@color/muted_fg" android:textSize="11sp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Tombol Play/Pause -->
        <Button
            android:id="@+id/btnPlayPause"
            android:text="▶  Mulai"
            android:textColor="@color/bg"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_lime"
            android:layout_width="match_parent"
            android:layout_height="60dp"/>
    </LinearLayout>
</LinearLayout>