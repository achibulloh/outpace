<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- MAP / PATH SECTION -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#0F0F12">

                <!-- Real Map for Route -->
                <org.osmdroid.views.MapView
                    android:id="@+id/mapDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- Map Loading Placeholder -->
                <View
                    android:id="@+id/viewMapDim"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#80000000"
                    android:visibility="gone"/>

                <!-- Top Buttons -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:layout_marginTop="30dp">

                    <FrameLayout
                        android:id="@+id/btnBack"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_circle_bg"
                        android:backgroundTint="#B3000000"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_back"
                            app:tint="@color/text_primary"/>
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btnShareTop"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/icon_circle_bg"
                        android:backgroundTint="#B3C8F43A">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_nav_progress"
                            app:tint="@color/bg"/>
                    </FrameLayout>
                </RelativeLayout>

                <!-- Markers Legend -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginStart="20dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_start"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:layout_marginEnd="15dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_finish"
                        android:textColor="@color/lime"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetailDistanceTop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="20dp"
                    android:text="5.20 km"
                    android:textColor="@color/lime"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

            </RelativeLayout>

            <!-- ACTIVITY INFO -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <LinearLayout
                    android:id="@+id/llTitleContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/tvDetailLocation"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:id="@+id/tvDetailRunTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Berlari"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvDetailDateTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Hari ini · 06:30"
                        android:textColor="@color/muted_fg"
                        android:textSize="14sp"
                        android:singleLine="true"
                        android:ellipsize="end"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDetailLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignTop="@id/llTitleContainer"
                    android:text="Kota Bandung\nSukapura"
                    android:textColor="@color/muted_fg"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxWidth="160dp"
                    android:gravity="end"
                    android:lines="2"
                    android:ellipsize="end" />

            </RelativeLayout>

            <!-- Main Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="20dp">

                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:id="@+id/tvDetailDistance" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="5.20" android:textColor="@color/lime" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_km_upper" android:textColor="@color/muted_fg" android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:id="@+id/tvDetailAvgPace" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="5:14" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_avg_pace_upper" android:textColor="@color/muted_fg" android:textSize="10sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:id="@+id/tvDetailDuration" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="27:14" android:textColor="@color/text_primary" android:textSize="24sp" android:textStyle="bold"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_duration_upper" android:textColor="@color/muted_fg" android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- TABS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/card_glass"
                android:padding="5dp"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/btnTabRingkasan"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="match_parent"
                    android:background="@drawable/btn_lime">
                    <TextView
                        android:id="@+id/tvTabRingkasan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/tab_summary"
                        android:textStyle="bold"
                        android:textColor="@color/bg"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/btnTabSplit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1">
                    <TextView
                        android:id="@+id/tvTabSplit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="@string/tab_split"
                        android:textColor="@color/muted_fg" />
                </FrameLayout>
            </LinearLayout>

            <!-- TAB CONTENT: RINGKASAN -->
            <LinearLayout
                android:id="@+id/layoutRingkasan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:visibility="visible">

                <!-- 4 Mini Cards -->
                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="4"
                    android:rowCount="1">

                    <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:background="@drawable/card_glass" android:padding="12dp" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <TextView android:id="@+id/tvDetailCalories" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="338" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_calories_label" android:textColor="@color/muted_fg" android:textSize="10sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:background="@drawable/card_glass" android:padding="12dp" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <TextView android:id="@+id/tvDetailSteps" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="6,933" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_steps_label" android:textColor="@color/muted_fg" android:textSize="10sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:background="@drawable/card_glass" android:padding="12dp" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                        <TextView android:id="@+id/tvDetailElevation" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="15 m" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_elevation_gain" android:textColor="@color/muted_fg" android:textSize="10sp"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_columnWeight="1" android:layout_height="wrap_content" android:background="@drawable/card_glass" android:padding="12dp" android:orientation="vertical" android:gravity="center">
                        <TextView android:id="@+id/tvDetailMaxElev" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="18 m" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_max_elevation" android:textColor="@color/muted_fg" android:textSize="10sp"/>
                    </LinearLayout>
                </GridLayout>

                <!-- Pace Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pace" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="min/km" android:textColor="#C8F43A" android:background="@drawable/card_glass" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textSize="11sp"/>
                    </RelativeLayout>
                    <com.example.pace.views.LineChartView
                        android:id="@+id/chartPace"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="15dp"
                        app:chartColor="@color/lime"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp">
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:id="@+id/tvDetailPaceAvg" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="--:-- /km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_pace_avg" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:id="@+id/tvDetailPaceTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="--:-- /km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_pace_total" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:id="@+id/tvDetailPaceFast" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="--:-- /km" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_fastest_split" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Kadens Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Kadens" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="langkah/mnt" android:textColor="#409C27B0" android:background="@drawable/card_glass" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textSize="11sp"/>
                    </RelativeLayout>
                    <com.example.pace.views.LineChartView
                        android:id="@+id/chartKadens"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="15dp"
                        app:chartColor="#9C27B0"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp">
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:id="@+id/tvDetailCadenceAvg" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="-- spm" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_cadence_avg" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:id="@+id/tvDetailCadenceMax" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="-- spm" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_cadence_max" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Elevasi Chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Elevasi" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="18sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="meter" android:textColor="#40FF9800" android:background="@drawable/card_glass" android:paddingHorizontal="8dp" android:paddingVertical="2dp" android:textSize="11sp"/>
                    </RelativeLayout>
                    <com.example.pace.views.LineChartView
                        android:id="@+id/chartElevasi"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="15dp"
                        app:chartColor="#FF9800"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="15dp">
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:id="@+id/tvDetailElevGain" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="-- m" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_elevation_gain" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:id="@+id/tvDetailElevMax" android:layout_width="wrap_content" android:layout_height="wrap_content" tools:text="-- m" android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="14sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/stat_max_elevation" android:textColor="@color/muted_fg" android:textSize="11sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- AI Insights Section -->
                <LinearLayout
                    android:id="@+id/layoutAIInsights"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_logo"
                            app:tint="@color/lime"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ai_coach_title"
                            android:textColor="@color/lime"
                            android:textStyle="bold"
                            android:textSize="16sp"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvAIInsights"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/ai_generating"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:lineSpacingExtra="4dp"
                        android:alpha="0.8"/>

                    <ProgressBar
                        android:id="@+id/pbAI"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"/>
                </LinearLayout>

            </LinearLayout>

            <!-- TAB CONTENT: SPLIT -->
            <LinearLayout
                android:id="@+id/layoutSplit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_glass"
                    android:padding="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tab_split"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="16dp"/>

                    <!-- Table Header -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingBottom="10dp" android:paddingHorizontal="4dp">
                        <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="Km" android:textColor="@color/muted_fg" android:textSize="12sp" />
                        <TextView android:layout_width="70dp" android:layout_height="wrap_content" android:text="Pace" android:textColor="@color/muted_fg" android:textSize="12sp" />
                        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />
                        <TextView android:layout_width="40dp" android:layout_height="wrap_content" android:text="Elev" android:textColor="@color/muted_fg" android:textSize="12sp" android:gravity="end"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#22FFFFFF" android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/llSplitContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM BUTTON -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="20dp"
        android:background="@drawable/bottom_nav_gradient">

        <LinearLayout
            android:id="@+id/btnShare"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/btn_lime"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_nav_progress"
                app:tint="@color/bg"
                android:layout_marginEnd="10dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_share_activity"
                android:textColor="@color/bg"
                android:textStyle="bold"
                android:textSize="16sp"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
